# Keep secrets, local state and bulk out of the build context / image.
# Runtime config is provided by mounting backend/.env (see docker-compose.prod.yml).
.git
.gitignore
.env
.env.*
vendor
node_modules
tests
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
.phpunit.result.cache
phpunit.xml
README.md
