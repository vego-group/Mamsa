# ── Frontend environment ─────────────────────────────────────────
# Copy to .env.local for local overrides. In production set these in the
# Vercel project (Settings → Environment Variables).

# Public API base URL (must include the /api/v1 suffix).
# Leave EMPTY in local dev — the Vite proxy forwards /api to the local backend.
# In production point it at the deployed Laravel API, e.g.:
#   VITE_API_BASE_URL=https://api.mamsa.example/api/v1
VITE_API_BASE_URL=

# Set to 1 when running the dev server behind an HTTPS tunnel (ngrok) so HMR
# uses the public wss port. Leave unset otherwise.
# VITE_TUNNEL=1
